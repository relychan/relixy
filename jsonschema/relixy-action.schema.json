{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$ref": "#/$defs/RelixyActionConfig",
 "$defs": {
  "EnvAny": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "description": "Default literal value if the env is empty"
    },
    "env": {
     "type": "string",
     "description": "Environment variable to be evaluated"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "EnvString": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "type": "string",
     "description": "Default literal value if the env is empty"
    },
    "env": {
     "type": "string",
     "description": "Environment variable to be evaluated"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "FieldMappingEntryConfig": {
   "properties": {
    "path": {
     "type": "string",
     "description": "JMESPath expression to find a value in the input data"
    },
    "default": {
     "$ref": "#/$defs/EnvAny",
     "description": "Default value to be used when no value is found"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "FieldMappingEntryStringConfig": {
   "properties": {
    "path": {
     "type": "string"
    },
    "default": {
     "$ref": "#/$defs/EnvString"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyActionConfig": {
   "oneOf": [
    {
     "$ref": "#/$defs/RelixyRESTActionConfig",
     "description": "Proxy configuration to the remote REST service"
    },
    {
     "$ref": "#/$defs/RelixyGraphQLActionConfig",
     "description": "Configurations for proxying request to the remote GraphQL server"
    }
   ]
  },
  "RelixyCustomGraphQLResponseConfig": {
   "properties": {
    "httpErrorCode": {
     "type": "integer",
     "maximum": 599,
     "minimum": 400,
     "default": 400
    },
    "body": {
     "$ref": "#/$defs/TemplateTransformerConfig"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyCustomRESTResponseConfig": {
   "properties": {
    "body": {
     "$ref": "#/$defs/TemplateTransformerConfig"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyGraphQLActionConfig": {
   "properties": {
    "type": {
     "type": "string",
     "enum": [
      "graphql"
     ]
    },
    "request": {
     "$ref": "#/$defs/RelixyGraphQLRequestConfig"
    },
    "response": {
     "$ref": "#/$defs/RelixyCustomGraphQLResponseConfig"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "type"
   ]
  },
  "RelixyGraphQLRequestConfig": {
   "properties": {
    "headers": {
     "additionalProperties": {
      "$ref": "#/$defs/FieldMappingEntryStringConfig"
     },
     "type": "object"
    },
    "query": {
     "type": "string"
    },
    "variables": {
     "additionalProperties": {
      "$ref": "#/$defs/FieldMappingEntryConfig"
     },
     "type": "object"
    },
    "extensions": {
     "additionalProperties": {
      "$ref": "#/$defs/FieldMappingEntryConfig"
     },
     "type": "object"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "query"
   ]
  },
  "RelixyRESTActionConfig": {
   "properties": {
    "type": {
     "type": "string",
     "enum": [
      "rest"
     ]
    },
    "request": {
     "$ref": "#/$defs/RelixyRESTRequestConfig"
    },
    "response": {
     "$ref": "#/$defs/RelixyCustomRESTResponseConfig"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "type"
   ]
  },
  "RelixyRESTRequestConfig": {
   "properties": {
    "path": {
     "type": "string"
    },
    "headers": {
     "additionalProperties": {
      "$ref": "#/$defs/FieldMappingEntryStringConfig"
     },
     "type": "object"
    },
    "body": {
     "$ref": "#/$defs/TemplateTransformerConfig"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "TemplateTransformerConfig": {
   "$ref": "https://raw.githubusercontent.com/relychan/gotransform/refs/heads/main/jsonschema/gotransform.schema.json"
  }
 }
}
