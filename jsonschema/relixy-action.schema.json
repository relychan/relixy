{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$ref": "#/$defs/RelixyActionConfig",
 "$defs": {
  "EnvAny": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "description": "Default literal value if the env is empty"
    },
    "env": {
     "type": "string",
     "description": "Environment variable to be evaluated"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "GraphQLVariableDefinition": {
   "properties": {
    "path": {
     "type": "string"
    },
    "default": {
     "$ref": "#/$defs/EnvAny"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyActionConfig": {
   "oneOf": [
    {
     "$ref": "#/$defs/RelixyRESTActionConfig",
     "description": "Proxy configuration to the remote REST service"
    },
    {
     "$ref": "#/$defs/RelixyGraphQLActionConfig",
     "description": "Configurations for proxying request to the remote GraphQL server"
    }
   ]
  },
  "RelixyGraphQLActionConfig": {
   "properties": {
    "type": {
     "type": "string",
     "enum": [
      "graphql"
     ]
    },
    "request": {
     "$ref": "#/$defs/RelixyGraphQLRequestConfig"
    },
    "response": {
     "$ref": "#/$defs/RelixyResponseRawConfig"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "type",
    "request",
    "response"
   ]
  },
  "RelixyGraphQLRequestConfig": {
   "properties": {
    "query": {
     "type": "string"
    },
    "variables": {
     "additionalProperties": {
      "$ref": "#/$defs/GraphQLVariableDefinition"
     },
     "type": "object",
     "description": "Definition of GraphQL variables."
    },
    "extensions": {
     "additionalProperties": {
      "$ref": "#/$defs/GraphQLVariableDefinition"
     },
     "type": "object",
     "description": "Definition of GraphQL extensions."
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyRESTActionConfig": {
   "properties": {
    "type": {
     "type": "string",
     "enum": [
      "rest"
     ]
    },
    "request": {
     "$ref": "#/$defs/RelixyRESTRequestConfig"
    },
    "response": {
     "$ref": "#/$defs/RelixyResponseRawConfig"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "type",
    "request",
    "response"
   ]
  },
  "RelixyRESTRequestConfig": {
   "properties": {
    "path": {
     "type": "string"
    },
    "transform": {
     "$ref": "#/$defs/TemplateTransformerConfig"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyResponseConfig": {
   "properties": {
    "HTTPErrorCode": {
     "type": "integer"
    },
    "Transform": true
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "HTTPErrorCode",
    "Transform"
   ]
  },
  "RelixyResponseRawConfig": {
   "properties": {
    "httpErrorCode": {
     "type": "integer",
     "maximum": 599,
     "minimum": 400,
     "default": 400
    },
    "transform": {
     "$ref": "#/$defs/TemplateTransformerConfig"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "TemplateTransformerConfig": {
   "$ref": "https://raw.githubusercontent.com/relychan/gotransform/refs/heads/main/jsonschema/gotransform.schema.json"
  }
 }
}
