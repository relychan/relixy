{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://github.com/relychan/relixy/schema/openapi/relixy-open-api3-resource-specification",
 "$ref": "#/$defs/RelixyOpenAPI3ResourceSpecification",
 "$defs": {
  "Components": {
   "properties": {
    "schemas": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/base.SchemaProxy]"
    },
    "responses": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Response]"
    },
    "parameters": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Parameter]"
    },
    "examples": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/base.Example]"
    },
    "requestBodies": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.RequestBody]"
    },
    "headers": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Header]"
    },
    "securitySchemes": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.SecurityScheme]"
    },
    "links": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Link]"
    },
    "callbacks": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Callback]"
    },
    "pathItems": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.PathItem]"
    },
    "mediaTypes": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.MediaType]"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "Contact": {
   "properties": {
    "name": {
     "type": "string"
    },
    "url": {
     "type": "string"
    },
    "email": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "Discriminator": {
   "properties": {
    "propertyName": {
     "type": "string"
    },
    "mapping": {
     "additionalProperties": {
      "type": "string"
     },
     "type": "object",
     "description": "An object to hold mappings between payload values and schema names or URI reference"
    },
    "defaultMapping": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "propertyName"
   ]
  },
  "Duration": {
   "type": "string",
   "minLength": 2,
   "pattern": "^(\\d+(\\.\\d+)?h)?(\\d+(\\.\\d+)?m)?(\\d+(\\.\\d+)?s)?(\\d+(\\.\\d+)?ms)?$",
   "description": "Duration string"
  },
  "EnvAny": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "description": "Default literal value if the env is empty"
    },
    "env": {
     "type": "string",
     "description": "Environment variable to be evaluated"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "EnvBool": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "type": "boolean",
     "description": "Default literal value if the env is empty"
    },
    "env": {
     "type": "string",
     "description": "Environment variable to be evaluated"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "EnvInt": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "type": "integer",
     "description": "Default literal value if the env is empty"
    },
    "env": {
     "type": "string",
     "description": "Environment variable to be evaluated"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "EnvString": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "type": "string",
     "description": "Default literal value if the env is empty"
    },
    "env": {
     "type": "string",
     "description": "Environment variable to be evaluated"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "ExternalDoc": {
   "properties": {
    "description": {
     "type": "string"
    },
    "url": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "GraphQLVariableDefinition": {
   "properties": {
    "path": {
     "type": "string"
    },
    "default": {
     "$ref": "#/$defs/EnvAny"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "HTTPClientAuthConfig": {
   "properties": {
    "HTTPClientAuthenticatorConfig": true
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "HTTPClientAuthenticatorConfig"
   ]
  },
  "HTTPClientConfig": {
   "$ref": "https://raw.githubusercontent.com/relychan/gohttpc/refs/heads/main/jsonschema/gohttpc.schema.json"
  },
  "HTTPDialerConfig": {
   "properties": {
    "timeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "keepAliveEnabled": {
     "type": "boolean"
    },
    "keepAliveInterval": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "keepAliveCount": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "keepAliveIdle": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "fallbackDelay": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "HTTPHealthCheckConfig": {
   "$ref": "https://raw.githubusercontent.com/relychan/gohttpc/refs/heads/main/jsonschema/gohttpc.schema.json#/$defs/HTTPHealthCheckConfig"
  },
  "HTTPRetryConfig": {
   "properties": {
    "maxAttempts": {
     "$ref": "#/$defs/EnvInt"
    },
    "delay": {
     "type": "integer"
    },
    "maxDelay": {
     "type": "integer"
    },
    "httpStatus": {
     "items": {
      "type": "integer"
     },
     "type": "array"
    },
    "multiplier": {
     "type": "number"
    },
    "jitter": {
     "type": "integer"
    },
    "jitterFactor": {
     "type": "number"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "HTTPTransportConfig": {
   "properties": {
    "dialer": {
     "$ref": "#/$defs/HTTPDialerConfig"
    },
    "idleConnTimeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "responseHeaderTimeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "tlsHandshakeTimeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "expectContinueTimeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "maxIdleConns": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "maxIdleConnsPerHost": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "maxConnsPerHost": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "maxResponseHeaderBytes": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "readBufferSize": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "writeBufferSize": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "disableKeepAlives": {
     "type": "boolean"
    },
    "forceAttemptHTTP2": {
     "type": "boolean"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "Info": {
   "properties": {
    "summary": {
     "type": "string"
    },
    "title": {
     "type": "string"
    },
    "description": {
     "type": "string"
    },
    "termsOfService": {
     "type": "string"
    },
    "contact": {
     "$ref": "#/$defs/Contact"
    },
    "license": {
     "$ref": "#/$defs/License"
    },
    "version": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "License": {
   "properties": {
    "name": {
     "type": "string"
    },
    "url": {
     "type": "string"
    },
    "identifier": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/base.Example]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/base.SchemaProxy]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Callback]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Header]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Link]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.MediaType]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Parameter]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.PathItem]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.RequestBody]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Response]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.SecurityScheme]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*go.yaml.in/yaml/v4.Node]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "OAuthFlow": {
   "properties": {
    "authorizationUrl": {
     "type": "string"
    },
    "tokenUrl": {
     "$ref": "#/$defs/EnvString"
    },
    "refreshUrl": {
     "type": "string"
    },
    "scopes": {
     "additionalProperties": {
      "type": "string"
     },
     "type": "object"
    },
    "clientId": {
     "$ref": "#/$defs/EnvString"
    },
    "clientSecret": {
     "$ref": "#/$defs/EnvString"
    },
    "endpointParams": {
     "additionalProperties": {
      "$ref": "#/$defs/EnvString"
     },
     "type": "object"
    },
    "deviceAuthorizationUrl": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "OrderedMap[string,*github.com/relychan/relixy/schema/openapi.RelixyEncoding]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "OrderedMap[string,*github.com/relychan/relixy/schema/openapi.RelixyHeader]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "OrderedMap[string,*github.com/relychan/relixy/schema/openapi.RelixyMediaType]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "OrderedMap[string,*github.com/relychan/relixy/schema/openapi.RelixyOpenAPIv3Operation]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "OrderedMap[string,*github.com/relychan/relixy/schema/openapi.RelixyOpenAPIv3PathItem]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "OrderedMap[string,*github.com/relychan/relixy/schema/openapi.RelixyOpenAPIv3Schema]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "OrderedMap[string,[]string]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "OrderedMap[string,string]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Parameter": {
   "properties": {
    "name": {
     "type": "string"
    },
    "in": {
     "$ref": "#/$defs/ParameterLocation"
    },
    "description": {
     "type": "string"
    },
    "required": {
     "type": "boolean"
    },
    "deprecated": {
     "type": "boolean"
    },
    "allowEmptyValue": {
     "type": "boolean"
    },
    "style": {
     "type": "string"
    },
    "explode": {
     "type": "boolean"
    },
    "allowReserved": {
     "type": "boolean"
    },
    "schema": {
     "$ref": "#/$defs/RelixyOpenAPIv3Schema"
    },
    "content": {
     "additionalProperties": {
      "$ref": "#/$defs/RelixyMediaType"
     },
     "type": "object",
     "description": "A map containing the representations for the parameter. The key is the media type and the value describes it. The map MUST only contain one entry."
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "name",
    "in"
   ]
  },
  "ParameterLocation": {
   "type": "string",
   "enum": [
    "query",
    "header",
    "path",
    "cookie",
    "body",
    "formData"
   ],
   "description": "Location of the parameter which is defined in OpenAPI specifications"
  },
  "PrimitiveType": {
   "type": "string",
   "enum": [
    "string",
    "number",
    "integer",
    "boolean",
    "array",
    "object",
    "null"
   ],
   "description": "A primitive type in OpenAPI specification"
  },
  "RelixyAPIKeyAuthConfig": {
   "properties": {
    "type": {
     "type": "string",
     "enum": [
      "apiKey"
     ]
    },
    "in": {
     "type": "string",
     "enum": [
      "query",
      "header",
      "cookie"
     ]
    },
    "name": {
     "type": "string"
    },
    "value": {
     "$ref": "#/$defs/EnvString"
    },
    "deprecated": {
     "type": "boolean"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "type",
    "in",
    "name",
    "value"
   ]
  },
  "RelixyAction": {
   "oneOf": [
    {
     "properties": {
      "type": {
       "type": "string",
       "enum": [
        "rest"
       ],
       "description": "Type of the proxy action"
      },
      "path": {
       "type": "string",
       "description": "Overrides the request path. Use the original request path if empty"
      }
     },
     "type": "object",
     "required": [
      "type"
     ],
     "title": "RelixyActionREST",
     "description": "Proxy configuration to the remote REST service"
    },
    {
     "properties": {
      "type": {
       "type": "string",
       "enum": [
        "graphql"
       ],
       "description": "Type of the proxy action"
      },
      "request": {
       "$ref": "#/$defs/RelixyGraphQLRequestConfig",
       "description": "Configuration for the GraphQL request"
      },
      "response": {
       "$ref": "#/$defs/RelixyGraphQLResponseConfig",
       "description": "Configuration for the GraphQL response"
      }
     },
     "type": "object",
     "required": [
      "type",
      "request"
     ],
     "title": "RelixyActionGraphQL",
     "description": "Configurations for proxying request to the remote GraphQL server"
    }
   ]
  },
  "RelixyBasicAuthConfig": {
   "properties": {
    "type": {
     "type": "string",
     "enum": [
      "basic"
     ]
    },
    "name": {
     "type": "string"
    },
    "username": {
     "$ref": "#/$defs/EnvString"
    },
    "password": {
     "$ref": "#/$defs/EnvString"
    },
    "deprecated": {
     "type": "boolean"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "type",
    "name",
    "username",
    "password"
   ]
  },
  "RelixyCookieAuthConfig": {
   "properties": {
    "type": {
     "type": "string",
     "enum": [
      "cookie"
     ]
    },
    "deprecated": {
     "type": "boolean"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "type"
   ]
  },
  "RelixyEncoding": {
   "properties": {
    "contentType": {
     "type": "string"
    },
    "headers": {
     "additionalProperties": {
      "$ref": "#/$defs/RelixyHeader"
     },
     "type": "object",
     "description": "A map allowing additional information to be provided as headers. Content-Type is described separately and SHALL be ignored in this section. This field SHALL be ignored if the media type is not a multipart."
    },
    "style": {
     "type": "string"
    },
    "explode": {
     "type": "boolean"
    },
    "allowReserved": {
     "type": "boolean"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyGraphQLRequestConfig": {
   "properties": {
    "query": {
     "type": "string",
     "description": "GraphQL query string to send"
    },
    "variables": {
     "additionalProperties": {
      "$ref": "#/$defs/GraphQLVariableDefinition"
     },
     "type": "object",
     "description": "Definition of GraphQL variables"
    },
    "extensions": {
     "additionalProperties": {
      "$ref": "#/$defs/GraphQLVariableDefinition"
     },
     "type": "object",
     "description": "Definition of GraphQL extensions"
    }
   },
   "type": "object",
   "required": [
    "query"
   ]
  },
  "RelixyGraphQLResponseConfig": {
   "properties": {
    "httpErrorCode": {
     "type": "integer",
     "default": 400
    },
    "transform": {
     "oneOf": [
      {
       "$ref": "https://raw.githubusercontent.com/relychan/gotransform/refs/heads/main/jsonschema/gotransform.schema.json"
      },
      {
       "type": "null"
      }
     ]
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyHTTPAuthConfig": {
   "properties": {
    "type": {
     "type": "string",
     "enum": [
      "http"
     ]
    },
    "name": {
     "type": "string"
    },
    "scheme": {
     "type": "string"
    },
    "value": {
     "$ref": "#/$defs/EnvString"
    },
    "bearerFormat": {
     "type": "string"
    },
    "deprecated": {
     "type": "boolean"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "type",
    "name",
    "scheme",
    "value"
   ]
  },
  "RelixyHeader": {
   "properties": {
    "description": {
     "type": "string"
    },
    "required": {
     "type": "boolean"
    },
    "deprecated": {
     "type": "boolean"
    },
    "style": {
     "type": "string"
    },
    "explode": {
     "type": "boolean"
    },
    "schema": {
     "$ref": "#/$defs/RelixyOpenAPIv3Schema"
    },
    "content": {
     "additionalProperties": {
      "$ref": "#/$defs/RelixyMediaType"
     },
     "type": "object"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyHealthCheckConfig": {
   "properties": {
    "http": {
     "$ref": "#/$defs/HTTPHealthCheckConfig"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyMediaType": {
   "properties": {
    "schema": {
     "$ref": "#/$defs/RelixyOpenAPIv3Schema"
    },
    "itemSchema": {
     "$ref": "#/$defs/RelixyOpenAPIv3Schema"
    },
    "encoding": {
     "additionalProperties": {
      "$ref": "#/$defs/RelixyEncoding"
     },
     "type": "object",
