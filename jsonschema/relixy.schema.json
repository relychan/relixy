{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://github.com/relychan/relixy/schema/openapi/relixy-open-api-resource",
 "$ref": "#/$defs/RelixyOpenAPIResource",
 "$defs": {
  "EnvBool": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "type": "boolean",
     "description": "Default literal value if the env is empty"
    },
    "env": {
     "type": "string",
     "description": "Environment variable to be evaluated"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "EnvString": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "type": "string",
     "description": "Default literal value if the env is empty"
    },
    "env": {
     "type": "string",
     "description": "Environment variable to be evaluated"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "HTTPClientConfig": {
   "$ref": "https://raw.githubusercontent.com/relychan/gohttpc/refs/heads/main/jsonschema/gohttpc.schema.json"
  },
  "HTTPHealthCheckConfig": {
   "properties": {
    "path": {
     "type": "string"
    },
    "method": {
     "type": "string",
     "enum": [
      "GET",
      "POST"
     ],
     "default": "GET"
    },
    "body": true,
    "headers": {
     "additionalProperties": {
      "$ref": "#/$defs/EnvString"
     },
     "type": "object"
    },
    "interval": {
     "type": "integer",
     "default": 60
    },
    "timeout": {
     "type": "integer",
     "default": 5
    },
    "successStatus": {
     "type": "integer",
     "enum": [
      200,
      201,
      204
     ],
     "default": 200
    },
    "successThreshold": {
     "type": "integer",
     "default": 1
    },
    "failureThreshold": {
     "type": "integer",
     "default": 3
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "path"
   ]
  },
  "RelixyHealthCheckConfig": {
   "properties": {
    "http": {
     "$ref": "#/$defs/HTTPHealthCheckConfig"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyOpenAPIForwardHeadersConfig": {
   "properties": {
    "request": {
     "items": {
      "type": "string"
     },
     "type": "array"
    },
    "response": {
     "items": {
      "type": "string"
     },
     "type": "array"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyOpenAPIResource": {
   "properties": {
    "version": {
     "type": "string",
     "enum": [
      "v1"
     ]
    },
    "kind": {
     "type": "string",
     "const": "OpenAPI",
     "description": "Kind of the resource which is always OpenAPI."
    },
    "metadata": {
     "$ref": "#/$defs/RelixyResourceMetadata"
    },
    "definition": {
     "$ref": "#/$defs/RelixyOpenAPIResourceDefinition"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "version",
    "kind",
    "metadata",
    "definition"
   ]
  },
  "RelixyOpenAPIResourceDefinition": {
   "properties": {
    "settings": {
     "$ref": "#/$defs/RelixyOpenAPISettings"
    },
    "ref": {
     "type": "string"
    },
    "spec": {
     "$ref": "https://raw.githubusercontent.com/relychan/relixy/refs/heads/main/jsonschema/openapi-3.json",
     "title": "OpenAPIv3Document",
     "description": "Specification of the OpenAPI v3 documentation."
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyOpenAPISettings": {
   "properties": {
    "expose": {
     "type": "boolean"
    },
    "basePath": {
     "type": "string"
    },
    "http": {
     "$ref": "#/$defs/HTTPClientConfig"
    },
    "headers": {
     "additionalProperties": {
      "$ref": "#/$defs/EnvString"
     },
     "type": "object"
    },
    "forwardHeaders": {
     "$ref": "#/$defs/RelixyOpenAPIForwardHeadersConfig"
    },
    "healthCheck": {
     "$ref": "#/$defs/RelixyHealthCheckConfig"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyResourceMetadata": {
   "properties": {
    "name": {
     "type": "string",
     "default": "default"
    },
    "description": {
     "type": "string"
    },
    "instruction": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "name"
   ]
  }
 }
}
