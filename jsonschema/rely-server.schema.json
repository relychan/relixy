{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://github.com/relychan/relixy/config/rely-server-config",
 "$ref": "#/$defs/RelyServerConfig",
 "$defs": {
  "ClientIPConfig": {
   "properties": {
    "type": {
     "type": "string"
    },
    "headers": {
     "items": {
      "type": "string"
     },
     "type": "array"
    },
    "trustedIpPrefixes": {
     "items": {
      "type": "string"
     },
     "type": "array"
    },
    "numTrustedProxies": {
     "type": "integer"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "type"
   ]
  },
  "OTLPConfig": {
   "$ref": "https://raw.githubusercontent.com/hasura/gotel/refs/heads/main/jsonschema/gotel.schema.json",
   "description": "Configurations for OpenTelemetry exporters"
  },
  "RelyDefinitionFileConfig": {
   "properties": {
    "include": {
     "items": {
      "type": "string"
     },
     "type": "array",
     "description": "List of paths to be included for metadata introspection."
    },
    "exclude": {
     "items": {
      "type": "string"
     },
     "type": "array",
     "description": "List of paths to be excluded for metadata introspection."
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "include"
   ],
   "description": "RelyDefinitionFileConfig represents the configurations for definition files."
  },
  "RelyServerConfig": {
   "properties": {
    "server": {
     "$ref": "#/$defs/ServerConfig",
     "description": "Configurations for the HTTP server."
    },
    "telemetry": {
     "$ref": "#/$defs/OTLPConfig",
     "description": "Configurations for OpenTelemetry exporters."
    },
    "definition": {
     "$ref": "#/$defs/RelyDefinitionFileConfig",
     "description": "Configurations for resource definition files."
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "definition"
   ],
   "description": "RelyServerConfig holds information of required configurations to run the Rely API server."
  },
  "ServerConfig": {
   "$ref": "https://raw.githubusercontent.com/relychan/gohttps/refs/heads/main/jsonschema/server.schema.json",
   "description": "Configurations for the HTTP server"
  }
 }
}
