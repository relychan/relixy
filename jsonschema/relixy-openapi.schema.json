{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://github.com/relychan/relixy/schema/openapi/relixy-open-ap-iv3-resource",
 "$ref": "#/$defs/RelixyOpenAPIv3Resource",
 "$defs": {
  "Components": {
   "properties": {
    "schemas": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/base.SchemaProxy]"
    },
    "responses": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Response]"
    },
    "parameters": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Parameter]"
    },
    "examples": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/base.Example]"
    },
    "requestBodies": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.RequestBody]"
    },
    "headers": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Header]"
    },
    "securitySchemes": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.SecurityScheme]"
    },
    "links": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Link]"
    },
    "callbacks": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Callback]"
    },
    "pathItems": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.PathItem]"
    },
    "mediaTypes": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.MediaType]"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "Contact": {
   "properties": {
    "name": {
     "type": "string"
    },
    "url": {
     "type": "string"
    },
    "email": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "Document": {
   "properties": {
    "openapi": {
     "type": "string"
    },
    "info": {
     "$ref": "#/$defs/Info"
    },
    "servers": {
     "items": {
      "$ref": "#/$defs/Server"
     },
     "type": "array"
    },
    "paths": {
     "$ref": "#/$defs/Paths"
    },
    "components": {
     "$ref": "#/$defs/Components"
    },
    "security": {
     "items": {
      "$ref": "#/$defs/SecurityRequirement"
     },
     "type": "array"
    },
    "tags": {
     "items": {
      "$ref": "#/$defs/Tag"
     },
     "type": "array"
    },
    "externalDocs": {
     "$ref": "#/$defs/ExternalDoc"
    },
    "jsonSchemaDialect": {
     "type": "string"
    },
    "$self": {
     "type": "string"
    },
    "webhooks": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.PathItem]"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "Duration": {
   "type": "string",
   "minLength": 2,
   "pattern": "^(\\d+(\\.\\d+)?h)?(\\d+(\\.\\d+)?m)?(\\d+(\\.\\d+)?s)?(\\d+(\\.\\d+)?ms)?$",
   "description": "Duration string"
  },
  "EnvBool": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "type": "boolean",
     "description": "Default literal value if the env is empty"
    },
    "env": {
     "type": "string",
     "description": "Environment variable to be evaluated"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "EnvInt": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "type": "integer",
     "description": "Default literal value if the env is empty"
    },
    "env": {
     "type": "string",
     "description": "Environment variable to be evaluated"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "EnvString": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "type": "string",
     "description": "Default literal value if the env is empty"
    },
    "env": {
     "type": "string",
     "description": "Environment variable to be evaluated"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "ExternalDoc": {
   "properties": {
    "description": {
     "type": "string"
    },
    "url": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "HTTPClientAuthConfig": {
   "properties": {
    "HTTPClientAuthenticatorConfig": true
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "HTTPClientAuthenticatorConfig"
   ]
  },
  "HTTPClientConfig": {
   "properties": {
    "timeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "transport": {
     "$ref": "#/$defs/HTTPTransportConfig"
    },
    "tls": {
     "$ref": "#/$defs/TLSConfig"
    },
    "retry": {
     "$ref": "#/$defs/HTTPRetryConfig"
    },
    "authentication": {
     "$ref": "#/$defs/HTTPClientAuthConfig"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "HTTPDialerConfig": {
   "properties": {
    "timeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "keepAliveEnabled": {
     "type": "boolean"
    },
    "keepAliveInterval": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "keepAliveCount": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "keepAliveIdle": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "fallbackDelay": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "HTTPHealthCheckConfig": {
   "properties": {
    "path": {
     "type": "string"
    },
    "method": {
     "type": "string",
     "enum": [
      "GET",
      "POST"
     ],
     "default": "GET"
    },
    "body": true,
    "headers": {
     "additionalProperties": {
      "$ref": "#/$defs/EnvString"
     },
     "type": "object"
    },
    "interval": {
     "type": "integer",
     "default": 60
    },
    "timeout": {
     "type": "integer",
     "default": 5
    },
    "successStatus": {
     "type": "integer",
     "enum": [
      200,
      201,
      204
     ],
     "default": 200
    },
    "successThreshold": {
     "type": "integer",
     "default": 1
    },
    "failureThreshold": {
     "type": "integer",
     "default": 3
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "path"
   ]
  },
  "HTTPRetryConfig": {
   "properties": {
    "maxAttempts": {
     "$ref": "#/$defs/EnvInt"
    },
    "delay": {
     "type": "integer"
    },
    "maxDelay": {
     "type": "integer"
    },
    "httpStatus": {
     "items": {
      "type": "integer"
     },
     "type": "array"
    },
    "multiplier": {
     "type": "number"
    },
    "jitter": {
     "type": "integer"
    },
    "jitterFactor": {
     "type": "number"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "HTTPTransportConfig": {
   "properties": {
    "dialer": {
     "$ref": "#/$defs/HTTPDialerConfig"
    },
    "idleConnTimeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "responseHeaderTimeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "tlsHandshakeTimeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "expectContinueTimeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "maxIdleConns": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "maxIdleConnsPerHost": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "maxConnsPerHost": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "maxResponseHeaderBytes": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "readBufferSize": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "writeBufferSize": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "disableKeepAlives": {
     "type": "boolean"
    },
    "forceAttemptHTTP2": {
     "type": "boolean"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "Info": {
   "properties": {
    "summary": {
     "type": "string"
    },
    "title": {
     "type": "string"
    },
    "description": {
     "type": "string"
    },
    "termsOfService": {
     "type": "string"
    },
    "contact": {
     "$ref": "#/$defs/Contact"
    },
    "license": {
     "$ref": "#/$defs/License"
    },
    "version": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "License": {
   "properties": {
    "name": {
     "type": "string"
    },
    "url": {
     "type": "string"
    },
    "identifier": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/base.Example]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/base.SchemaProxy]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Callback]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Header]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Link]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.MediaType]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Parameter]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.PathItem]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.RequestBody]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.Response]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.SecurityScheme]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.ServerVariable]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Map[string,*go.yaml.in/yaml/v4.Node]": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "Paths": {
   "properties": {},
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyHealthCheckConfig": {
   "properties": {
    "http": {
     "$ref": "#/$defs/HTTPHealthCheckConfig"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyOpenAPIForwardHeadersConfig": {
   "properties": {
    "request": {
     "items": {
      "type": "string"
     },
     "type": "array"
    },
    "response": {
     "items": {
      "type": "string"
     },
     "type": "array"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyOpenAPISettings": {
   "properties": {
    "basePath": {
     "type": "string"
    },
    "http": {
     "$ref": "#/$defs/HTTPClientConfig"
    },
    "headers": {
     "additionalProperties": {
      "$ref": "#/$defs/EnvString"
     },
     "type": "object"
    },
    "forwardHeaders": {
     "$ref": "#/$defs/RelixyOpenAPIForwardHeadersConfig"
    },
    "healthCheck": {
     "$ref": "#/$defs/RelixyHealthCheckConfig"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "RelixyOpenAPIv3Resource": {
   "properties": {
    "version": {
     "type": "string",
     "enum": [
      "v1"
     ]
    },
    "kind": {
     "type": "string",
     "const": "OpenAPI3",
     "description": "Kind of the resource which is always OpenAPI3."
    },
    "metadata": {
     "$ref": "#/$defs/RelixyResourceMetadata"
    },
    "definition": {
     "$ref": "#/$defs/RelixyOpenAPIv3ResourceDefinition"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "version",
    "kind",
    "metadata",
    "definition"
   ]
  },
  "RelixyOpenAPIv3ResourceDefinition": {
   "properties": {
    "settings": {
     "$ref": "#/$defs/RelixyOpenAPISettings"
    },
    "spec": {
     "$ref": "openapi-3.2.json",
     "description": "Specification of the OpenAPI v3 documentation."
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "settings",
    "spec"
   ]
  },
  "RelixyResourceMetadata": {
   "properties": {
    "name": {
     "type": "string",
     "default": "default"
    },
    "description": {
     "type": "string"
    },
    "instruction": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "name"
   ]
  },
  "SecurityRequirement": {
   "properties": {
    "ContainsEmptyRequirement": {
     "type": "boolean"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "ContainsEmptyRequirement"
   ]
  },
  "Server": {
   "properties": {
    "name": {
     "type": "string"
    },
    "url": {
     "type": "string"
    },
    "description": {
     "type": "string"
    },
    "variables": {
     "$ref": "#/$defs/Map[string,*github.com/pb33f/libopenapi/datamodel/high/v3.ServerVariable]"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "TLSClientCertificate": {
   "properties": {
    "certFile": {
     "$ref": "#/$defs/EnvString"
    },
    "certPem": {
     "$ref": "#/$defs/EnvString"
    },
    "keyFile": {
     "$ref": "#/$defs/EnvString"
    },
    "keyPem": {
     "$ref": "#/$defs/EnvString"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "TLSConfig": {
   "properties": {
    "rootCAFile": {
     "items": {
      "$ref": "#/$defs/EnvString"
     },
     "type": "array"
    },
    "rootCAPem": {
     "items": {
      "$ref": "#/$defs/EnvString"
     },
     "type": "array"
    },
    "caFile": {
     "items": {
      "$ref": "#/$defs/EnvString"
     },
     "type": "array"
    },
    "caPem": {
     "items": {
      "$ref": "#/$defs/EnvString"
     },
     "type": "array"
    },
    "certificates": {
     "items": {
      "$ref": "#/$defs/TLSClientCertificate"
     },
     "type": "array"
    },
    "insecureSkipVerify": {
     "$ref": "#/$defs/EnvBool"
    },
    "includeSystemCACertsPool": {
     "$ref": "#/$defs/EnvBool"
    },
    "minVersion": {
     "type": "string"
    },
    "maxVersion": {
     "type": "string"
    },
    "cipherSuites": {
     "items": {
      "type": "string"
     },
     "type": "array"
    },
    "serverName": {
     "$ref": "#/$defs/EnvString"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "Tag": {
   "properties": {
    "name": {
     "type": "string"
    },
    "summary": {
     "type": "string"
    },
    "description": {
     "type": "string"
    },
    "externalDocs": {
     "$ref": "#/$defs/ExternalDoc"
    },
    "parent": {
     "type": "string"
    },
    "kind": {
     "type": "string"
    },
    "Extensions": {
     "$ref": "#/$defs/Map[string,*go.yaml.in/yaml/v4.Node]"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "Extensions"
   ]
  }
 }
}
