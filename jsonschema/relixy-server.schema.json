{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://github.com/relychan/relixy/config/relixy-server-config",
 "$ref": "#/$defs/RelixyServerConfig",
 "$defs": {
  "OTLPConfig": {
   "$ref": "https://raw.githubusercontent.com/hasura/gotel/refs/heads/main/jsonschema/gotel.schema.json",
   "description": "Configurations for OpenTelemetry exporters"
  },
  "RelixyDefinitionConfig": {
   "properties": {
    "include": {
     "items": {
      "type": "string"
     },
     "type": "array",
     "description": "List of paths to be included for metadata introspection."
    },
    "exclude": {
     "items": {
      "type": "string"
     },
     "type": "array",
     "description": "List of paths to be excluded for metadata introspection."
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "include"
   ],
   "description": "RelixyDefinitionConfig represents the configurations for relixy definitions."
  },
  "RelixyServerConfig": {
   "properties": {
    "server": {
     "$ref": "#/$defs/ServerConfig",
     "description": "Configurations for the HTTP server."
    },
    "telemetry": {
     "$ref": "#/$defs/OTLPConfig",
     "description": "Configurations for OpenTelemetry exporters."
    },
    "definition": {
     "$ref": "#/$defs/RelixyDefinitionConfig",
     "description": "Configurations for resource definition files."
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "definition"
   ],
   "description": "RelixyServerConfig holds information of required configurations to run the relixy server."
  },
  "ServerConfig": {
   "$ref": "https://raw.githubusercontent.com/relychan/gohttps/refs/heads/main/jsonschema/server.schema.json",
   "description": "Configurations for the HTTP server"
  }
 }
}
