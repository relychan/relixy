{
    "$schema": "https://json-schema.org/draft/2020-12/schema",
    "$id": "https://github.com/relychan/relyx/schema/relyx-api-document",
    "$ref": "#/$defs/RelyProxyAPIDocument",
    "$defs": {
        "Discriminator": {
            "properties": {
                "propertyName": {
                    "type": "string"
                },
                "mapping": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object"
                },
                "defaultMapping": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "Duration": {
            "type": "string",
            "pattern": "^((([0-9]+h)?([0-9]+m)?([0-9]+s))|(([0-9]+h)?([0-9]+m))|([0-9]+h))$",
            "description": "Duration string"
        },
        "EnvAny": {
            "anyOf": [
                {
                    "required": [
                        "value"
                    ],
                    "title": "value"
                },
                {
                    "required": [
                        "env"
                    ],
                    "title": "env"
                }
            ],
            "properties": {
                "value": true,
                "env": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "EnvBool": {
            "anyOf": [
                {
                    "required": [
                        "value"
                    ],
                    "title": "value"
                },
                {
                    "required": [
                        "env"
                    ],
                    "title": "env"
                }
            ],
            "properties": {
                "value": {
                    "type": "boolean"
                },
                "env": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "EnvInt": {
            "anyOf": [
                {
                    "required": [
                        "value"
                    ],
                    "title": "value"
                },
                {
                    "required": [
                        "env"
                    ],
                    "title": "env"
                }
            ],
            "properties": {
                "value": {
                    "type": "integer"
                },
                "env": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "EnvString": {
            "anyOf": [
                {
                    "required": [
                        "value"
                    ],
                    "title": "value"
                },
                {
                    "required": [
                        "env"
                    ],
                    "title": "env"
                }
            ],
            "properties": {
                "value": {
                    "type": "string"
                },
                "env": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "GraphQLVariableDefinition": {
            "properties": {
                "expression": {
                    "type": "string"
                },
                "default": {
                    "$ref": "#/$defs/EnvAny"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "HTTPClientAuthConfig": {
            "properties": {
                "HTTPClientAuthenticatorConfig": true
            },
            "additionalProperties": false,
            "type": "object",
            "required": [
                "HTTPClientAuthenticatorConfig"
            ]
        },
        "HTTPClientConfig": {
            "properties": {
                "timeout": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/Duration"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "transport": {
                    "$ref": "#/$defs/HTTPTransportConfig"
                },
                "tls": {
                    "$ref": "#/$defs/TLSConfig"
                },
                "retry": {
                    "$ref": "#/$defs/HTTPRetryConfig"
                },
                "authentication": {
                    "$ref": "#/$defs/HTTPClientAuthConfig"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "HTTPDialerConfig": {
            "properties": {
                "timeout": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/Duration"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "keepAliveEnabled": {
                    "type": "boolean"
                },
                "keepAliveInterval": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/Duration"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "keepAliveCount": {
                    "oneOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "keepAliveIdle": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/Duration"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "fallbackDelay": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/Duration"
                        },
                        {
                            "type": "null"
                        }
                    ]
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "HTTPHealthCheckConfig": {
            "properties": {
                "path": {
                    "type": "string"
                },
                "method": {
                    "type": "string",
                    "enum": [
                        "GET",
                        "POST"
                    ],
                    "default": "GET"
                },
                "body": true,
                "headers": {
                    "additionalProperties": {
                        "$ref": "#/$defs/EnvString"
                    },
                    "type": "object"
                },
                "interval": {
                    "type": "integer",
                    "default": 60
                },
                "timeout": {
                    "type": "integer",
                    "default": 5
                },
                "successStatus": {
                    "type": "integer",
                    "enum": [
                        200,
                        201,
                        204
                    ],
                    "default": 200
                },
                "successThreshold": {
                    "type": "integer",
                    "default": 1
                },
                "failureThreshold": {
                    "type": "integer",
                    "default": 3
                }
            },
            "additionalProperties": false,
            "type": "object",
            "required": [
                "path"
            ]
        },
        "HTTPRetryConfig": {
            "properties": {
                "maxAttempts": {
                    "$ref": "#/$defs/EnvInt"
                },
                "delay": {
                    "type": "integer"
                },
                "maxDelay": {
                    "type": "integer"
                },
                "httpStatus": {
                    "items": {
                        "type": "integer"
                    },
                    "type": "array"
                },
                "multiplier": {
                    "type": "number"
                },
                "jitter": {
                    "type": "integer"
                },
                "jitterFactor": {
                    "type": "number"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "HTTPTransportConfig": {
            "properties": {
                "dialer": {
                    "$ref": "#/$defs/HTTPDialerConfig"
                },
                "idleConnTimeout": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/Duration"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "responseHeaderTimeout": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/Duration"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "tlsHandshakeTimeout": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/Duration"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "expectContinueTimeout": {
                    "oneOf": [
                        {
                            "$ref": "#/$defs/Duration"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "maxIdleConns": {
                    "oneOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "maxIdleConnsPerHost": {
                    "oneOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "maxConnsPerHost": {
                    "oneOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "maxResponseHeaderBytes": {
                    "oneOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "readBufferSize": {
                    "oneOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "writeBufferSize": {
                    "oneOf": [
                        {
                            "type": "integer"
                        },
                        {
                            "type": "null"
                        }
                    ]
                },
                "disableKeepAlives": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "OAuthFlow": {
            "properties": {
                "authorizationUrl": {
                    "type": "string"
                },
                "tokenUrl": {
                    "$ref": "#/$defs/EnvString"
                },
                "refreshUrl": {
                    "type": "string"
                },
                "scopes": {
                    "additionalProperties": {
                        "type": "string"
                    },
                    "type": "object"
                },
                "clientId": {
                    "$ref": "#/$defs/EnvString"
                },
                "clientSecret": {
                    "$ref": "#/$defs/EnvString"
                },
                "endpointParams": {
                    "additionalProperties": {
                        "$ref": "#/$defs/EnvString"
                    },
                    "type": "object"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "Parameter": {
            "properties": {
                "name": {
                    "type": "string"
                },
                "in": {
                    "type": "string",
                    "enum": [
                        "query",
                        "header",
                        "path",
                        "cookie",
                        "body",
                        "formData"
                    ]
                },
                "description": {
                    "type": "string"
                },
                "required": {
                    "type": "boolean"
                },
                "deprecated": {
                    "type": "boolean"
                },
                "allowEmptyValue": {
                    "type": "boolean"
                },
                "style": {
                    "type": "string"
                },
                "explode": {
                    "type": "boolean"
                },
                "allowReserved": {
                    "type": "boolean"
                },
                "schema": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "content": {
                    "additionalProperties": {
                        "$ref": "#/$defs/RelyProxyMediaType"
                    },
                    "type": "object"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxyAPIDocument": {
            "properties": {
                "$schema": {
                    "type": "string"
                },
                "settings": {
                    "$ref": "#/$defs/RelyProxySettings"
                },
                "info": {
                    "$ref": "#/$defs/RelyProxyAPIDocumentInfo"
                },
                "servers": {
                    "items": {
                        "$ref": "#/$defs/RelyProxyServer"
                    },
                    "type": "array"
                },
                "security": {
                    "items": {
                        "$ref": "#/$defs/SecurityRequirements"
                    },
                    "type": "array"
                },
                "tags": {
                    "items": {
                        "$ref": "#/$defs/RelyProxyTag"
                    },
                    "type": "array"
                },
                "paths": {
                    "additionalProperties": {
                        "$ref": "#/$defs/RelyProxyPathItem"
                    },
                    "type": "object"
                }
            },
            "additionalProperties": false,
            "type": "object",
            "required": [
                "settings",
                "servers",
                "paths"
            ]
        },
        "RelyProxyAPIDocumentInfo": {
            "properties": {
                "summary": {
                    "type": "string"
                },
                "title": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "termsOfService": {
                    "type": "string"
                },
                "contact": {
                    "$ref": "#/$defs/RelyProxyAPIDocumentInfoContact"
                },
                "license": {
                    "$ref": "#/$defs/RelyProxyAPIDocumentInfoLicense"
                },
                "version": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxyAPIDocumentInfoContact": {
            "properties": {
                "name": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                },
                "email": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxyAPIDocumentInfoLicense": {
            "properties": {
                "name": {
                    "type": "string"
                },
                "url": {
                    "type": "string"
                },
                "identifier": {
                    "type": "string"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxyAction": {
            "oneOf": [
                {
                    "properties": {
                        "type": {
                            "type": "string",
                            "enum": [
                                "rest"
                            ],
                            "description": "Type of the proxy action"
                        },
                        "path": {
                            "type": "string",
                            "description": "Overrides the request path. Use the original request path if empty"
                        }
                    },
                    "type": "object",
                    "required": [
                        "type"
                    ],
                    "description": "Proxy configuration to the remote REST service"
                },
                {
                    "properties": {
                        "type": {
                            "type": "string",
                            "enum": [
                                "graphql"
                            ],
                            "description": "Type of the proxy action"
                        },
                        "request": {
                            "$ref": "#/$defs/RelyProxyGraphQLRequestConfig",
                            "description": "Configuration for the GraphQL request"
                        },
                        "response": {
                            "$ref": "#/$defs/RelyProxyGraphQLResponseConfig",
                            "description": "Configuration for the GraphQL response"
                        }
                    },
                    "type": "object",
                    "required": [
                        "type",
                        "request"
                    ],
                    "description": "Configurations for proxying request to the remote GraphQL server"
                }
            ]
        },
        "RelyProxyEncoding": {
            "properties": {
                "contentType": {
                    "type": "string"
                },
                "headers": {
                    "additionalProperties": {
                        "$ref": "#/$defs/RelyProxyHeader"
                    },
                    "type": "object"
                },
                "style": {
                    "type": "string"
                },
                "explode": {
                    "type": "boolean"
                },
                "allowReserved": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxyForwardHeadersConfig": {
            "properties": {
                "request": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "response": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxyGraphQLRequestConfig": {
            "properties": {
                "query": {
                    "type": "string",
                    "description": "GraphQL query string to send"
                },
                "variables": {
                    "additionalProperties": {
                        "$ref": "#/$defs/GraphQLVariableDefinition"
                    },
                    "type": "object"
                },
                "extensions": {
                    "additionalProperties": {
                        "$ref": "#/$defs/GraphQLVariableDefinition"
                    },
                    "type": "object"
                }
            },
            "type": "object",
            "required": [
                "query"
            ]
        },
        "RelyProxyGraphQLResponseConfig": {
            "properties": {
                "httpErrorCode": {
                    "type": "integer",
                    "default": 400
                },
                "transform": {
                    "$ref": "#/$defs/TemplateTransformerConfig"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxyHeader": {
            "properties": {
                "description": {
                    "type": "string"
                },
                "required": {
                    "type": "boolean"
                },
                "deprecated": {
                    "type": "boolean"
                },
                "allowEmptyValue": {
                    "type": "boolean"
                },
                "style": {
                    "type": "string"
                },
                "explode": {
                    "type": "boolean"
                },
                "allowReserved": {
                    "type": "boolean"
                },
                "schema": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "content": {
                    "additionalProperties": {
                        "$ref": "#/$defs/RelyProxyMediaType"
                    },
                    "type": "object"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxyHealthCheckConfig": {
            "properties": {
                "http": {
                    "$ref": "#/$defs/HTTPHealthCheckConfig"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxyMediaType": {
            "properties": {
                "schema": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "itemSchema": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "encoding": {
                    "additionalProperties": {
                        "$ref": "#/$defs/RelyProxyEncoding"
                    },
                    "type": "object"
                },
                "itemEncoding": {
                    "additionalProperties": {
                        "$ref": "#/$defs/RelyProxyEncoding"
                    },
                    "type": "object"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxyOperation": {
            "properties": {
                "tags": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "summary": {
                    "type": "string"
                },
                "description": {
                    "type": "string"
                },
                "operationId": {
                    "type": "string"
                },
                "parameters": {
                    "items": {
                        "$ref": "#/$defs/Parameter"
                    },
                    "type": "array"
                },
                "requestBody": {
                    "$ref": "#/$defs/RelyProxyRequestBody"
                },
                "deprecated": {
                    "type": "boolean"
                },
                "security": {
                    "$ref": "#/$defs/SecurityRequirements"
                },
                "proxy": {
                    "$ref": "#/$defs/RelyProxyAction"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxyPathItem": {
            "properties": {
                "description": {
                    "type": "string"
                },
                "summary": {
                    "type": "string"
                },
                "get": {
                    "$ref": "#/$defs/RelyProxyOperation"
                },
                "put": {
                    "$ref": "#/$defs/RelyProxyOperation"
                },
                "post": {
                    "$ref": "#/$defs/RelyProxyOperation"
                },
                "delete": {
                    "$ref": "#/$defs/RelyProxyOperation"
                },
                "patch": {
                    "$ref": "#/$defs/RelyProxyOperation"
                },
                "parameters": {
                    "items": {
                        "$ref": "#/$defs/Parameter"
                    },
                    "type": "array"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxyRequestBody": {
            "properties": {
                "description": {
                    "type": "string"
                },
                "content": {
                    "additionalProperties": {
                        "$ref": "#/$defs/RelyProxyMediaType"
                    },
                    "type": "object"
                },
                "required": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxySchema": {
            "properties": {
                "$schema": {
                    "type": "string"
                },
                "$ref": {
                    "type": "string"
                },
                "exclusiveMaximum": {
                    "type": "number"
                },
                "exclusiveMinimum": {
                    "type": "number"
                },
                "type": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "allOf": {
                    "items": {
                        "$ref": "#/$defs/RelyProxySchema"
                    },
                    "type": "array"
                },
                "oneOf": {
                    "items": {
                        "$ref": "#/$defs/RelyProxySchema"
                    },
                    "type": "array"
                },
                "anyOf": {
                    "items": {
                        "$ref": "#/$defs/RelyProxySchema"
                    },
                    "type": "array"
                },
                "discriminator": {
                    "$ref": "#/$defs/Discriminator"
                },
                "prefixItems": {
                    "items": {
                        "$ref": "#/$defs/RelyProxySchema"
                    },
                    "type": "array"
                },
                "contains": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "minContains": {
                    "type": "integer"
                },
                "maxContains": {
                    "type": "integer"
                },
                "if": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "else": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "then": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "dependentSchemas": {
                    "additionalProperties": {
                        "$ref": "#/$defs/RelyProxySchema"
                    },
                    "type": "object"
                },
                "dependentRequired": {
                    "additionalProperties": {
                        "items": {
                            "type": "string"
                        },
                        "type": "array"
                    },
                    "type": "object"
                },
                "patternProperties": {
                    "additionalProperties": {
                        "$ref": "#/$defs/RelyProxySchema"
                    },
                    "type": "object"
                },
                "propertyNames": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "unevaluatedItems": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "items": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "$anchor": {
                    "type": "string"
                },
                "not": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "properties": {
                    "additionalProperties": {
                        "$ref": "#/$defs/RelyProxySchema"
                    },
                    "type": "object"
                },
                "title": {
                    "type": "string"
                },
                "multipleOf": {
                    "type": "number"
                },
                "maximum": {
                    "type": "number"
                },
                "minimum": {
                    "type": "number"
                },
                "maxLength": {
                    "type": "integer"
                },
                "minLength": {
                    "type": "integer"
                },
                "pattern": {
                    "type": "string"
                },
                "format": {
                    "type": "string"
                },
                "maxItems": {
                    "type": "integer"
                },
                "minItems": {
                    "type": "integer"
                },
                "uniqueItems": {
                    "type": "boolean"
                },
                "maxProperties": {
                    "type": "integer"
                },
                "minProperties": {
                    "type": "integer"
                },
                "required": {
                    "items": {
                        "type": "string"
                    },
                    "type": "array"
                },
                "enum": {
                    "items": true,
                    "type": "array"
                },
                "additionalProperties": {
                    "$ref": "#/$defs/RelyProxySchema"
                },
                "description": {
                    "type": "string"
                },
                "default": true,
                "const": true,
                "nullable": {
                    "type": "boolean"
                },
                "readOnly": {
                    "type": "boolean"
                },
                "writeOnly": {
                    "type": "boolean"
                },
                "deprecated": {
                    "type": "boolean"
                }
            },
            "additionalProperties": false,
            "type": "object"
        },
        "RelyProxySecurityScheme": {
            "oneOf": [
                {
                    "properties": {
                        "type": {
                            "type": "string",
                            "enum": [
                                "apiKey"
                            ]
                        },
                        "value": {
                            "$ref": "#/$defs/EnvString"
                        },
                        "in": {
                            "type": "string",
                            "enum": [
                                "header",
                                "query",
                                "cookie"
                            ]
                        },
                        "name": {
                            "type": "string"
                        }
                    },
