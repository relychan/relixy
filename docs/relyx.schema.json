{
 "$schema": "https://json-schema.org/draft/2020-12/schema",
 "$id": "https://github.com/relychan/relyx/schema/rely-proxy-api-document",
 "$ref": "#/$defs/RelyProxyAPIDocument",
 "$defs": {
  "Discriminator": {
   "properties": {
    "propertyName": {
     "type": "string"
    },
    "mapping": {
     "additionalProperties": {
      "type": "string"
     },
     "type": "object"
    },
    "defaultMapping": {
     "type": "string",
     "description": "OpenAPI 3.2+ defaultMapping for fallback schema"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "Discriminator is only used by OpenAPI 3+ documents, it represents a polymorphic discriminator used for schemas\nWhen request bodies or response payloads may be one of a number of different schemas, a discriminator object can be used to aid in serialization, deserialization, and validation.\nThe discriminator is a specific object in a schema which is used to inform the consumer of the document of an alternative schema based on the value associated with it.\nWhen using the discriminator, inline schemas will not be considered."
  },
  "Duration": {
   "type": "string",
   "minLength": 2,
   "pattern": "^(\\d+(\\.\\d+)?h)?(\\d+(\\.\\d+)?m)?(\\d+(\\.\\d+)?s)?(\\d+(\\.\\d+)?ms)?$",
   "description": "Duration string"
  },
  "EnvAny": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": true,
    "env": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "EnvBool": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "type": "boolean"
    },
    "env": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "EnvInt": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "type": "integer"
    },
    "env": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "EnvString": {
   "anyOf": [
    {
     "required": [
      "value"
     ],
     "title": "value"
    },
    {
     "required": [
      "env"
     ],
     "title": "env"
    }
   ],
   "properties": {
    "value": {
     "type": "string"
    },
    "env": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "GraphQLVariableDefinition": {
   "properties": {
    "expression": {
     "type": "string"
    },
    "default": {
     "$ref": "#/$defs/EnvAny"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "GraphQLVariableDefinition defines information of the GraphQL variable."
  },
  "HTTPClientAuthConfig": {
   "properties": {
    "HTTPClientAuthenticatorConfig": true
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "HTTPClientAuthenticatorConfig"
   ]
  },
  "HTTPClientConfig": {
   "properties": {
    "timeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "transport": {
     "$ref": "#/$defs/HTTPTransportConfig"
    },
    "tls": {
     "$ref": "#/$defs/TLSConfig"
    },
    "retry": {
     "$ref": "#/$defs/HTTPRetryConfig"
    },
    "authentication": {
     "$ref": "#/$defs/HTTPClientAuthConfig"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "HTTPDialerConfig": {
   "properties": {
    "timeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "keepAliveEnabled": {
     "type": "boolean"
    },
    "keepAliveInterval": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "keepAliveCount": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "keepAliveIdle": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "fallbackDelay": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "HTTPHealthCheckConfig": {
   "properties": {
    "path": {
     "type": "string"
    },
    "method": {
     "type": "string",
     "enum": [
      "GET",
      "POST"
     ],
     "default": "GET"
    },
    "body": true,
    "headers": {
     "additionalProperties": {
      "$ref": "#/$defs/EnvString"
     },
     "type": "object"
    },
    "interval": {
     "type": "integer",
     "default": 60
    },
    "timeout": {
     "type": "integer",
     "default": 5
    },
    "successStatus": {
     "type": "integer",
     "enum": [
      200,
      201,
      204
     ],
     "default": 200
    },
    "successThreshold": {
     "type": "integer",
     "default": 1
    },
    "failureThreshold": {
     "type": "integer",
     "default": 3
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "path"
   ]
  },
  "HTTPRetryConfig": {
   "properties": {
    "maxAttempts": {
     "$ref": "#/$defs/EnvInt"
    },
    "delay": {
     "type": "integer"
    },
    "maxDelay": {
     "type": "integer"
    },
    "httpStatus": {
     "items": {
      "type": "integer"
     },
     "type": "array"
    },
    "multiplier": {
     "type": "number"
    },
    "jitter": {
     "type": "integer"
    },
    "jitterFactor": {
     "type": "number"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "HTTPTransportConfig": {
   "properties": {
    "dialer": {
     "$ref": "#/$defs/HTTPDialerConfig"
    },
    "idleConnTimeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "responseHeaderTimeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "tlsHandshakeTimeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "expectContinueTimeout": {
     "oneOf": [
      {
       "$ref": "#/$defs/Duration"
      },
      {
       "type": "null"
      }
     ]
    },
    "maxIdleConns": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "maxIdleConnsPerHost": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "maxConnsPerHost": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "maxResponseHeaderBytes": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "readBufferSize": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "writeBufferSize": {
     "oneOf": [
      {
       "type": "integer"
      },
      {
       "type": "null"
      }
     ]
    },
    "disableKeepAlives": {
     "type": "boolean"
    }
   },
   "additionalProperties": false,
   "type": "object"
  },
  "OAuthFlow": {
   "properties": {
    "authorizationUrl": {
     "type": "string"
    },
    "tokenUrl": {
     "$ref": "#/$defs/EnvString"
    },
    "refreshUrl": {
     "type": "string"
    },
    "scopes": {
     "additionalProperties": {
      "type": "string"
     },
     "type": "object"
    },
    "clientId": {
     "$ref": "#/$defs/EnvString"
    },
    "clientSecret": {
     "$ref": "#/$defs/EnvString"
    },
    "endpointParams": {
     "additionalProperties": {
      "$ref": "#/$defs/EnvString"
     },
     "type": "object"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "OAuthFlow contains flow configurations for [OAuth 2.0] API specification\n\n[OAuth 2.0]: https://swagger.io/docs/specification/authentication/oauth2"
  },
  "Parameter": {
   "properties": {
    "name": {
     "type": "string"
    },
    "in": {
     "$ref": "#/$defs/ParameterLocation"
    },
    "description": {
     "type": "string"
    },
    "required": {
     "type": "boolean"
    },
    "deprecated": {
     "type": "boolean"
    },
    "allowEmptyValue": {
     "type": "boolean"
    },
    "style": {
     "type": "string"
    },
    "explode": {
     "type": "boolean"
    },
    "allowReserved": {
     "type": "boolean"
    },
    "schema": {
     "$ref": "#/$defs/RelyProxySchema"
    },
    "content": {
     "additionalProperties": {
      "$ref": "#/$defs/RelyProxyMediaType"
     },
     "type": "object"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "Parameter represents a high-level OpenAPI 3+ Parameter object, that is backed by a low-level one.\nA unique parameter is defined by a combination of a name and location.\nhttps://spec.openapis.org/oas/v3.1.0#parameter-object"
  },
  "ParameterLocation": {
   "type": "string",
   "enum": [
    "query",
    "header",
    "path",
    "cookie",
    "body",
    "formData"
   ],
   "description": "Location of the parameter which is defined in OpenAPI specifications"
  },
  "RelyProxyAPIDocument": {
   "properties": {
    "$schema": {
     "type": "string"
    },
    "settings": {
     "$ref": "#/$defs/RelyProxySettings",
     "description": "Global settings of the proxy."
    },
    "info": {
     "$ref": "#/$defs/RelyProxyAPIDocumentInfo",
     "description": "Info represents a specification Info definitions\nProvides metadata about the API. The metadata MAY be used by tooling as required.\n- https://spec.openapis.org/oas/v3.1.0#info-object"
    },
    "servers": {
     "items": {
      "$ref": "#/$defs/RelyProxyServer"
     },
     "type": "array",
     "description": "Servers is a slice of Server instances which provide connectivity information to a target server."
    },
    "security": {
     "items": {
      "$ref": "#/$defs/SecurityRequirements"
     },
     "type": "array",
     "description": "Security contains global security requirements/roles for the specification\nA declaration of which security mechanisms can be used across the API. The list of values includes alternative\nsecurity requirement objects that can be used. Only one of the security requirement objects need to be satisfied\nto authorize a request. Individual operations can override this definition. To make security optional,\nan empty security requirement ({}) can be included in the array."
    },
    "tags": {
     "items": {
      "$ref": "#/$defs/RelyProxyTag"
     },
     "type": "array",
     "description": "Tags is a slice of Tag instances defined by the specification\nA list of tags used by the document with additional metadata. The order of the tags can be used to reflect on\ntheir order by the parsing tools. Not all tags that are used by the Operation Object must be declared.\nThe tags that are not declared MAY be organized randomly or based on the tools’ logic.\nEach tag name in the list MUST be unique."
    },
    "paths": {
     "additionalProperties": {
      "$ref": "#/$defs/RelyProxyPathItem"
     },
     "type": "object"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "settings",
    "servers",
    "paths"
   ],
   "description": "RelyProxyAPIDocument represents the structure of an API document."
  },
  "RelyProxyAPIDocumentInfo": {
   "properties": {
    "summary": {
     "type": "string"
    },
    "title": {
     "type": "string"
    },
    "description": {
     "type": "string"
    },
    "termsOfService": {
     "type": "string"
    },
    "contact": {
     "$ref": "#/$defs/RelyProxyAPIDocumentInfoContact"
    },
    "license": {
     "$ref": "#/$defs/RelyProxyAPIDocumentInfoLicense"
    },
    "version": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "RelyProxyAPIDocumentInfo represents a high-level Info object that provides metadata about the API.\nThe metadata MAY be used by the clients if needed, and MAY be presented\nin editing or documentation generation tools for convenience."
  },
  "RelyProxyAPIDocumentInfoContact": {
   "properties": {
    "name": {
     "type": "string"
    },
    "url": {
     "type": "string"
    },
    "email": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "RelyProxyAPIDocumentInfoContact represents a high-level representation of the Contact definitions."
  },
  "RelyProxyAPIDocumentInfoLicense": {
   "properties": {
    "name": {
     "type": "string"
    },
    "url": {
     "type": "string"
    },
    "identifier": {
     "type": "string"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "RelyProxyAPIDocumentInfoLicense represents a high-level representation of the License definitions."
  },
  "RelyProxyAction": {
   "oneOf": [
    {
     "properties": {
      "type": {
       "type": "string",
       "enum": [
        "rest"
       ],
       "description": "Type of the proxy action"
      },
      "path": {
       "type": "string",
       "description": "Overrides the request path. Use the original request path if empty"
      }
     },
     "type": "object",
     "required": [
      "type"
     ],
     "description": "Proxy configuration to the remote REST service"
    },
    {
     "properties": {
      "type": {
       "type": "string",
       "enum": [
        "graphql"
       ],
       "description": "Type of the proxy action"
      },
      "request": {
       "$ref": "#/$defs/RelyProxyGraphQLRequestConfig",
       "description": "Configuration for the GraphQL request"
      },
      "response": {
       "$ref": "#/$defs/RelyProxyGraphQLResponseConfig",
       "description": "Configuration for the GraphQL response"
      }
     },
     "type": "object",
     "required": [
      "type",
      "request"
     ],
     "description": "Configurations for proxying request to the remote GraphQL server"
    }
   ]
  },
  "RelyProxyEncoding": {
   "properties": {
    "contentType": {
     "type": "string"
    },
    "headers": {
     "additionalProperties": {
      "$ref": "#/$defs/RelyProxyHeader"
     },
     "type": "object"
    },
    "style": {
     "type": "string"
    },
    "explode": {
     "type": "boolean"
    },
    "allowReserved": {
     "type": "boolean"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "RelyProxyEncoding represents an OpenAPI 3+ Encoding object\n  - https://spec.openapis.org/oas/v3.1.0#encoding-object"
  },
  "RelyProxyForwardHeadersConfig": {
   "properties": {
    "request": {
     "items": {
      "type": "string"
     },
     "type": "array",
     "description": "Defines header names to be forwarded from the client request."
    },
    "response": {
     "items": {
      "type": "string"
     },
     "type": "array",
     "description": "Defines header names to be forwarded from the response."
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "RelyProxyForwardHeadersConfig contains configurations for headers forwarding,."
  },
  "RelyProxyGraphQLRequestConfig": {
   "properties": {
    "query": {
     "type": "string",
     "description": "GraphQL query string to send"
    },
    "variables": {
     "additionalProperties": {
      "$ref": "#/$defs/GraphQLVariableDefinition"
     },
     "type": "object"
    },
    "extensions": {
     "additionalProperties": {
      "$ref": "#/$defs/GraphQLVariableDefinition"
     },
     "type": "object"
    }
   },
   "type": "object",
   "required": [
    "query"
   ]
  },
  "RelyProxyGraphQLResponseConfig": {
   "properties": {
    "httpErrorCode": {
     "type": "integer",
     "description": "HTTP error code will be used if the response body has errors.\nIf not set, forward the HTTP status from the GraphQL response which is usually 200 OK.",
     "default": 400
    },
    "transform": {
     "oneOf": [
      {
       "$ref": "https://raw.githubusercontent.com/relychan/gotransform/refs/heads/main/jsonschema/gotransform.schema.json"
      },
      {
       "type": "null"
      }
     ]
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "RelyProxyGraphQLResponseConfig represents configurations for the proxy response."
  },
  "RelyProxyHeader": {
   "properties": {
    "description": {
     "type": "string"
    },
    "required": {
     "type": "boolean"
    },
    "deprecated": {
     "type": "boolean"
    },
    "allowEmptyValue": {
     "type": "boolean"
    },
    "style": {
     "type": "string"
    },
    "explode": {
     "type": "boolean"
    },
    "allowReserved": {
     "type": "boolean"
    },
    "schema": {
     "$ref": "#/$defs/RelyProxySchema"
    },
    "content": {
     "additionalProperties": {
      "$ref": "#/$defs/RelyProxyMediaType"
     },
     "type": "object"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "RelyProxyHeader represents a high-level OpenAPI 3+ Header object that is backed by a low-level one.\n  - https://spec.openapis.org/oas/v3.1.0#header-object"
  },
  "RelyProxyHealthCheckConfig": {
   "properties": {
    "http": {
     "$ref": "#/$defs/HTTPHealthCheckConfig",
     "description": "Configurations for health check through HTTP protocol."
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "RelyProxyHealthCheckConfig holds health check configurations for server recovery."
  },
  "RelyProxyMediaType": {
   "properties": {
    "schema": {
     "$ref": "#/$defs/RelyProxySchema"
    },
    "itemSchema": {
     "$ref": "#/$defs/RelyProxySchema"
    },
    "encoding": {
     "additionalProperties": {
      "$ref": "#/$defs/RelyProxyEncoding"
     },
     "type": "object"
    },
    "itemEncoding": {
     "additionalProperties": {
      "$ref": "#/$defs/RelyProxyEncoding"
     },
     "type": "object"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "RelyProxyMediaType represents a high-level OpenAPI MediaType object that is backed by a low-level one.\n\nEach Media Type Object provides schema and examples for the media type identified by its key.\n  - https://spec.openapis.org/oas/v3.1.0#media-type-object"
  },
  "RelyProxyOperation": {
   "properties": {
    "tags": {
     "items": {
      "type": "string"
     },
     "type": "array",
     "description": "List of tags for this operation."
    },
    "summary": {
     "type": "string",
     "description": "Summary information of the operation."
    },
    "description": {
     "type": "string",
     "description": "Description of the operation."
    },
    "operationId": {
     "type": "string",
     "description": "ID of the operation. It should be unique."
    },
    "parameters": {
     "items": {
      "$ref": "#/$defs/Parameter"
     },
     "type": "array",
     "description": "Request parameters of the operation."
    },
    "requestBody": {
     "$ref": "#/$defs/RelyProxyRequestBody",
     "description": "Request body information."
    },
    "deprecated": {
     "type": "boolean",
     "description": "Responses   *highv3.Responses    `json:\"responses,omitempty\" yaml:\"responses,omitempty\"`\nDefines whether this operation is deprecated."
    },
    "security": {
     "$ref": "#/$defs/SecurityRequirements",
     "description": "Requires the security for this operation."
    },
    "proxy": {
     "$ref": "#/$defs/RelyProxyAction",
     "description": "Defines action information to proxy request to the remote server."
    }
   },
   "additionalProperties": false,
   "type": "object",
   "required": [
    "proxy"
   ],
   "description": "RelyProxyOperation represents the definition of an API operation."
  },
  "RelyProxyPathItem": {
   "properties": {
    "description": {
     "type": "string",
     "description": "Description of the path item."
    },
    "summary": {
     "type": "string",
     "description": "Summary of the path item."
    },
    "get": {
     "$ref": "#/$defs/RelyProxyOperation",
     "description": "Defines the operation information of the GET method."
    },
    "put": {
     "$ref": "#/$defs/RelyProxyOperation",
     "description": "Defines the operation information of the PUT method."
    },
    "post": {
     "$ref": "#/$defs/RelyProxyOperation",
     "description": "Defines the operation information of the POST method."
    },
    "delete": {
     "$ref": "#/$defs/RelyProxyOperation",
     "description": "Defines the operation information of the DELETE method."
    },
    "patch": {
     "$ref": "#/$defs/RelyProxyOperation",
     "description": "Defines the operation information of the PATCH method."
    },
    "parameters": {
     "items": {
      "$ref": "#/$defs/Parameter"
     },
     "type": "array",
     "description": "Common parameters of the path item."
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "RelyProxyPathItem represents a definition object of an API path item."
  },
  "RelyProxyRequestBody": {
   "properties": {
    "description": {
     "type": "string"
    },
    "content": {
     "additionalProperties": {
      "$ref": "#/$defs/RelyProxyMediaType"
     },
     "type": "object"
    },
    "required": {
     "type": "boolean"
    }
   },
   "additionalProperties": false,
   "type": "object",
   "description": "RelyProxyRequestBody represents a high-level OpenAPI 3+ RequestBody object, backed by a low-level one.\n  - https://spec.openapis.org/oas/v3.1.0#request-body-object"
  },
  "RelyProxySchema": {
   "properties": {
    "$schema": {
     "type": "string",
